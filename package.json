{
  "name": "stylusflow",
  "version": "0.2.1",
  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "build": "node scripts/build-release.js",
    "dev": "cd src && zip -r -q ../stylusflow-dev.mnaddon .",
    "listen:space-http": "CLANG_MODULE_CACHE_PATH=/tmp/stylusflow-swift-module-cache swift scripts/space-http-listener.swift",
    "version": "node scripts/bump-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.46.0"
  }
}
